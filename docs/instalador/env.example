# ====== DATOS DE TU CUENTA WYZE ======
# Llenar con el Bloc de notas y GUARDAR. Estos datos se quedan SOLO en esta compu.

WYZE_EMAIL=tu-correo@ejemplo.com
WYZE_PASSWORD=tu-clave-de-wyze

# ====== LLAVE API (gratis, 2 minutos) ======
# 1. Entra a: https://developer-api-console.wyze.com/#/apikey/view
# 2. Inicia sesion con tu cuenta Wyze y toca "Create API Key"
# 3. Copia el "API Key ID" y el "API Key" aqui abajo:

API_ID=pegar-aqui-el-api-key-id
API_KEY=pegar-aqui-el-api-key
